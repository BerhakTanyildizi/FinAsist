# Finasist Backend — Ortam Değişkenleri Şablonu
# ================================================
# Bu dosyayı `.env` olarak kopyalayın ve gerçek değerlerle doldurun:
#   cp .env.example .env   (veya Windows'ta: copy .env.example .env)
#
# GÜVENLİK: .env dosyasını ASLA git'e commit etmeyin, ASLA CLAUDE.md/README gibi
# commit edilen dosyalara gerçek secret değerleri yapıştırmayın. .env zaten
# .gitignore'dadır.

DATABASE_URL=postgresql://<kullanici>:<sifre>@localhost:5432/finasist_db

# Güçlü, rastgele bir secret üretin (ASLA tahmin edilebilir bir string kullanmayın):
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# aistudio.google.com adresinden alınan, "AIza" ile başlayan key
# (Google Cloud Console'dan alınan "AQ." formatındaki key'ler Gemini REST API ile çalışmaz)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# console.groq.com adresinden alınan ücretsiz key (fiş tarama + AI danışman fallback'i için)
GROQ_API_KEY=

# Üretim ortamında CORS'u gerçek domain'inizle sınırlamak için (opsiyonel).
# Boş bırakılırsa sadece localhost/127.0.0.1 (herhangi bir port) kabul edilir.
# Örnek: ALLOWED_ORIGIN_REGEX=^https://finasist\.com$
ALLOWED_ORIGIN_REGEX=
