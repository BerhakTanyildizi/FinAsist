# Docker Compose Kök Ortam Değişkenleri
# ==========================================
# Bu dosya SADECE docker-compose.yml'in PostgreSQL şifresini ayarlaması içindir.
# Uygulama secret'ları (SECRET_KEY, GROQ_API_KEY vb.) için backend/.env.example'a bakın.
#
# Kullanım: bu dosyayı `.env` olarak kopyalayıp güçlü bir şifre belirleyin.
#   cp .env.example .env   (Windows: copy .env.example .env)

POSTGRES_PASSWORD=
